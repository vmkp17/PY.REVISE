#The statistics module provides functions to perform statistical calculations on numerical data.

import statistics
marks = [90,80,60,70,100]
print(statistics.mean(marks))
print(statistics.median(marks))
print(statistics.mode(marks))
print(statistics.stdev(marks)) #Measures how spread out the values are from the average.
print(statistics.variance(marks))#It also measures how spread out the data is, but it is the square of the standard deviation
