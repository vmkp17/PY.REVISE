#collections is a built-in Python library that provides special data structures which are more powerful than normal lists, tuples, dictionaries and sets.
#Counter,defaultdict, deque, namedtuple, OrderedDict are the most commonly used data structures in the collections module.

#COUNTER: Counter is a subclass of dict that helps count hashable objects. It is an unordered collection where elements are stored as dictionary keys and their counts are stored as dictionary values.Counter counts how many times each element appears.
print("COUNTER EG")
from collections import Counter, namedtuple
names = ["Ali","Rahul","Ali","madhuri","Ali","madhuri","Rahul"]
count = Counter(names)
print(count)
